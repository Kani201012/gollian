# CommodityPulse .gitignore

# Environment / secrets — NEVER commit these
.env
*.env
.env.*
secrets.json

# State file (persisted between GitHub Actions runs via cache, not git)
signal_state.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# Logs — can be large, keep out of git
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Streamlit
.streamlit/secrets.toml
